---
import { Image } from "astro:assets";


interface Props {
      title: string;
      description: string;
      image: ImageMetadata
}

const { title, description, image } = Astro.props;

---

<div class="w-92 border border-white/20 p-4 rounded-2xl flex flex-col gap-2 duration-250 cursor-default hover:translate-x-2 hover:-translate-y-2 opacity-70 hover:opacity-100">
      <Image src={image} alt="Thunder Icon" width={40} />
      <h3 class="text-3xl font-bold">{title}</h3>
      <p class="font-semibold text-white/70">{description}</p>
</div>