---
import { Image } from "astro:assets";

import PageLoadImage from "../../assets/icons/page-load.svg";
import FirstPaintImage from "../../assets/icons/first-paint.svg";
import InteractivityImage from "../../assets/icons/interactivity.svg";
import PerformanceImage from "../../assets/icons/performance.svg";
import SEOImage from "../../assets/icons/seo.svg";

---

<div class="border-y border-white/20 py-16 px-18 flex flex-col items-center h-fit">
      <!-- Site Performance Title -->
      <div class="flex flex-col items-center">
            <p class="text-xl font-semibold opacity-50">This site's performance</p>
            <h1 class="mt-2 text-4xl font-thin">Practicing What I <span class="text-purple-700 font-bold">Preach</span></h1>
      </div>
      <!-- Performance List -->
      <ul class="performance-list">
            <li class="text-center w-full h-full flex flex-col gap-1 items-center border border-white/50 custom-window-level-shiny-element rounded-2xl p-6">
                  <Image width={50} src={PageLoadImage} alt="Page Load Icon" />
                  <p class="font-bold text-3xl">0.8<span class="text-md opacity-80">s</span></p>
                  <p class="font-semibold opacity-50">Page Load</p>
            </li>
            <li class="text-center w-full h-full flex flex-col gap-1 items-center border border-white/50 custom-window-level-shiny-element rounded-2xl p-6">
                  <Image width={50} src={FirstPaintImage} alt="First Paint Icon" />
                  <p class="font-bold text-3xl">180<span class="text-md opacity-80">ms</span></p>
                  <p class="font-semibold opacity-50">First Paint</p>
            </li>
            <li class="text-center w-full h-full flex flex-col gap-1 items-center border border-white/50 custom-window-level-shiny-element rounded-2xl p-6">
                  <Image width={50} src={InteractivityImage} alt="Interactivity Icon" />
                  <p class="font-bold text-3xl">512<span class="text-md opacity-80">ms</span></p>
                  <p class="font-semibold opacity-50">Interactive</p>
            </li>
            <li class="text-center w-full h-full flex flex-col gap-1 items-center border border-white/50 custom-window-level-shiny-element rounded-2xl p-6">
                  <Image width={50} src={PerformanceImage} alt="Performance Icon" />
                  <p class="font-bold text-3xl">99<span class="text-md opacity-80">/100</span></p>
                  <p class="font-semibold opacity-50">Performance</p>
            </li>
            <li class="text-center w-full h-full flex flex-col gap-1 items-center border border-white/50 custom-window-level-shiny-element rounded-2xl p-6">
                  <Image width={50} src={SEOImage} alt="SEO Icon" />
                  <p class="font-bold text-3xl">100<span class="text-md opacity-80">/100</span></p>
                  <p class="font-semibold opacity-50">SEO</p>
            </li>
      </ul>
      <!-- Performance Insight -->
      <p class="text-sm md:text-lg mt-8 opacity-75 font-thin text-center w-full">Optimized with <span class="font-bold">image optimization, static site generation, contents prioritization, complete meta descriptions,</span> and <span class="font-bold">javascript minfier</span></p>
</div>

<style>
      .performance-list {
            width: 100%;
            height: 100%;
            gap: 14px;
            margin-top: 60px;

            display: grid;
      }

      @media (min-width: 1400px) {
            .performance-list {
                  grid-template-columns: repeat(5, 1fr);
                  grid-template-rows: 1fr;
                  grid-template-areas: "page-load first-paint interactive performance seo";
            }
      }

      @media (max-width: 1400px) {
            .performance-list {
                  grid-template-columns: repeat(4, 1fr);
                  grid-template-rows: repeat(2, 1fr);
                  grid-template-areas: "page-load first-paint first-paint interactive"
                  "performance performance seo seo";
            }
      }
      
      @media (max-width: 800px) {
            .performance-list {
                  grid-template-columns: repeat(2, 1fr);
                  grid-template-rows: repeat(3, 1fr);
                  grid-template-areas: "page-load first-paint"
                  "interactive performance"
                  "seo seo";
            }
      }

      @media (max-width: 500px) {
            .performance-list {
                  grid-template-columns: 1fr;
                  grid-template-rows: repeat(5, 1fr);
                  grid-template-areas: "page-load"
                  "first-paint"
                  "interactive"
                  "performance"
                  "seo";
            }
      }

      .performance-list > *:nth-child(1) {
            grid-area: page-load;
      }
      .performance-list > *:nth-child(2) {
            grid-area: first-paint;
      }
      .performance-list > *:nth-child(3) {
            grid-area: interactive;
      }
      .performance-list > *:nth-child(4) {
            grid-area: performance;
      }
      .performance-list > *:nth-child(5) {
            grid-area: seo;
      }
</style>