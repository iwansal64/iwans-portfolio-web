---
import AnimationCircle from "../global/AnimationCircle";
import ShinyButtonWorker from "../global/ShinyButtonWorker.astro";

---

<div class="w-screen h-screen flex flex-col items-center justify-center">
      <ShinyButtonWorker />
      <span class="pointer-events-none absolute top-0 left-0 w-[50vw] h-[50vh] -translate-x-1/2 -translate-y-1/2 bg-radial from-white/10 to-70% to-transparent"></span>
      <span class="pointer-events-none absolute bottom-0 right-0 w-[50vw] h-[50vh] translate-x-1/3 translate-y-1/2 bg-radial from-purple-300/12 to-70% to-transparent"></span>
      <div class="w-4/5">
            <!-- Ready To Work -->
            <div class="scale-90 relative left-1/2 -translate-x-1/2 opacity-90 flex flex-row items-center gap-4 font-thin border border-white/30 bg-white/5 w-fit px-4 py-2 rounded-full">
                <AnimationCircle client:load />
                Available for work
            </div>
            <!-- Title -->
            <h1 class="mt-4 text-6xl md:text-8xl font-bold text-center tracking-tight text-shadow-2xl">
                  Building Systems<br />That <span class="bg-linear-to-r from-accent from-purple-700 to-purple-400 bg-clip-text text-transparent">Scale</span>
            </h1>
            <!-- Subtitle -->
            <p class="opacity-75 text-2xl text-center font-thin mt-2 w-2/3 relative left-1/2 -translate-x-1/2">
                  <span class="font-bold text-purple-600">Fullstack engineer</span> obsessed with <span class="italic">performance, modern architecture, </span>
                  and
                  <span class="italic">exceptional user experiences</span>
            </p>
            <!-- Action Buttons -->
            <div class="flex flex-row gap-4 justify-center items-center w-full h-fit p-4">
                  <button class="bg-white text-black py-4 px-8 rounded-full">View Projects</button>
                  <button class="bg-black text-white border border-white py-4 px-8 rounded-full custom-shiny-button">Get In Touch</button>
            </div>
      </div>
</div>
