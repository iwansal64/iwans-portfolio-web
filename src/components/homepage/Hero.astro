---
import AnimationCircle from "../global/AnimationCircle";

---

<main class="w-screen h-screen flex flex-col items-center justify-center">
      <div class="w-full md:w-4/5">
            <!-- Ready To Work -->
            <div class="scale-90 relative left-1/2 -translate-x-1/2 opacity-90 flex flex-row items-center gap-4 font-thin border border-white/30 bg-white/5 w-fit px-1 md:px-4 py-2 rounded-full">
                  <AnimationCircle client:idle />
                  Available for work
            </div>
            <!-- Title -->
            <div class="relative left-1/2 -translate-x-1/2 w-fit">
                  <span class="-z-100 pointer-events-none absolute top-0 left-0 w-[70vw] h-[50vh] -translate-x-1/2 -translate-y-1/2 bg-radial from-white/10 to-70% to-transparent"></span>
                  <span class="-z-100 pointer-events-none absolute bottom-0 right-0 w-[70vw] h-[50vh] translate-x-1/3 translate-y-1/2 bg-radial from-purple-300/12 to-70% to-transparent"></span>
                  <h1 class="mt-4 text-6xl md:text-8xl font-bold text-center tracking-tight text-shadow-2xl">
                        Building Systems<br />That <span class="bg-linear-to-r from-accent from-purple-500 to-purple-300 from-50% bg-clip-text text-transparent">Scale</span>
                  </h1>
            </div>
            <!-- Subtitle -->
            <p class="text-white/80 text-md md:text-2xl text-center font-thin mt-2 w-2/3 relative left-1/2 -translate-x-1/2">
                  <span class="font-bold text-purple-400">Fullstack engineer</span> obsessed with <span class="italic">performance, modern architecture, </span>
                  and
                  <span class="italic">exceptional user experiences</span>
            </p>
            <!-- Action Buttons -->
            <div class="mt-4 flex flex-row gap-4 justify-center items-center w-full h-fit md:p-4">
                  <button class="bg-white text-black py-2 px-4 md:py-4 md:px-8 rounded-full">View Projects</button>
                  <button class="bg-black text-white border border-white py-2 px-4 md:py-4 md:px-8 rounded-full custom-shiny-element">Get In Touch</button>
            </div>
      </div>
</main>
